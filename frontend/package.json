{
  "name": "netlayer",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:noc": "pnpm --filter @netlayer/noc dev",
    "dev:portal": "pnpm --filter @netlayer/portal dev",
    "dev:partner": "pnpm --filter @netlayer/partner dev",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
