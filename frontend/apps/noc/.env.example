# ── Netlayer NOC App — Environment Variables ──────────────────────────────────
# Copy to .env.local and fill in values. Never commit .env.local to git.

# Backend API base URL (without /api/v1)
VITE_API_URL=http://localhost:8000

# WebSocket base URL
VITE_WS_URL=ws://localhost:8000

# Grafana base URL (for embeds)
VITE_GRAFANA_URL=http://localhost:3000

# Zabbix base URL (for embed on Monitoring page)
VITE_ZABBIX_URL=http://localhost:8080

# App environment
VITE_APP_ENV=development
